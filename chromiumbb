#!/usr/bin/env -S guile -e main -s
!#
;;; chromiumbb — Chromium build, but better.
;;; Replaces depot_tools/gclient/gn/ninja with a single Guile tool.

(add-to-load-path (dirname (current-filename)))
(add-to-load-path (string-append (dirname (current-filename)) "/modules"))
(use-modules (chromiumbb cli))
(define (main args) (chromiumbb-main args))
